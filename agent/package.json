{
  "name": "itmanager-agent",
  "version": "1.0.0",
  "description": "ITManager Sunucu İzleme Ajanı",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.itmanager.agent",
    "productName": "ITManager Agent",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ITManager Agent",
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "ui/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
